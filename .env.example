# Which backend drives the tool-use loop: "anthropic" or "ollama".
LLM_PROVIDER=anthropic

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to claude-opus-4-8. Try claude-haiku-4-5 for a cheaper/faster demo.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# In Docker, host.docker.internal points at the host's Ollama server.
# Running locally without Docker, use http://localhost:11434 instead.
OLLAMA_HOST=http://host.docker.internal:11434

# Must be a tool-calling-capable model you've already pulled, e.g. `ollama pull llama3.1`.
OLLAMA_MODEL=llama3.1
