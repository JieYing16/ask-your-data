# Which LLM backend to use: "anthropic" (default, needs a paid API key) or
# "ollama" (free, runs locally, no key needed).
LLM_PROVIDER=anthropic

# --- Anthropic (LLM_PROVIDER=anthropic) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to claude-opus-4-8. Try claude-haiku-4-5 for a cheaper/faster demo.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Ollama (LLM_PROVIDER=ollama) ---
# Requires Ollama (https://ollama.com) running locally with a tool-calling-capable
# model pulled, e.g. `ollama pull llama3.1`.
OLLAMA_MODEL=llama3.1
# Use http://host.docker.internal:11434 instead when running via docker compose,
# so the container can reach Ollama on your host machine.
OLLAMA_HOST=http://localhost:11434
